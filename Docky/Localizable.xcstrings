    "Allow Docky in Privacy & Security so it can perform %@." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーとセキュリティでDockyを許可して、%@を実行できるようにしてください。"
          }
        }
      }
    },
    "Allow Docky to control %1$@ in Privacy & Security > Automation, then try %2$@ again." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que Docky controle %1$@ en Privacidad y Seguridad > Automatización y vuelve a intentar %2$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーとセキュリティ > オートメーションでDockyが%1$@を制御することを許可してから、%2$@を再試行してください。"
          }
        }
      }
    },
    "Allow Docky to control System Events and %1$@ in Privacy & Security > Automation, then try %2$@ again." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que Docky controle System Events y %1$@ en Privacidad y Seguridad > Automatización y vuelve a intentar %2$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーとセキュリティ > オートメーションでDockyがSystem Eventsおよび%1$@を制御することを許可してから、%2$@を再試行してください。"
          }
        }
      }
    },
    "Allows tiles to use the enlarged dock sizing behavior when enabled." : {
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que los íconos usen el comportamiento de tamaño ampliado del dock cuando está activado."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、タイルが拡大されたDockのサイズ動作を使用できるようになります。"
          }
        }
      }
    },
    "ALPHA" : {
      "comment" : "The text that appears as a badge indicating an alpha feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALPHA"
          }
        }
      }
    },
    "Alpha feature" : {
      "comment" : "An accessibility label for the alpha badge in the appearance settings view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アルファ機能"
          }
        }
      }
    },
    "Alphabetical" : {
      "comment" : "Title for the Launchpad sort mode option that sorts items alphabetically.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アルファベット順"
          }
        }
      }
    },
    "Always show a compact vertical list with app icons and window titles. No screen recording required." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostrar siempre una lista vertical compacta con íconos de apps y títulos de ventana. No requiere grabación de pantalla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appアイコンとウインドウタイトルをコンパクトな縦リストで常に表示します。画面収録は不要です。"
          }
        }
      }
    },
    "Always show window thumbnails. Requires screen recording permission to render preview images." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostrar siempre miniaturas de ventana. Requiere permiso de grabación de pantalla para renderizar las imágenes de vista previa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ウインドウのサムネールを常に表示します。プレビュー画像の表示には画面収録のアクセス権が必要です。"
          }
        }
      }
    },
    "An existing copy of Docky is already in Applications. Replacing it will keep the newer copy you just opened." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya existe una copia de Docky en Aplicaciones. Reemplazarla mantendrá la copia más nueva que acabas de abrir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dockyのコピーがすでにアプリケーションフォルダにあります。置き換えると、今開いた新しいコピーが保持されます。"
          }
        }
      }
    },
