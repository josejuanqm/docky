      }
    },
    "Use thumbnails when screen recording permission is granted; fall back to a compact list when previews aren't available." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa miniaturas cuando se haya concedido el permiso de grabación de pantalla; recurre a una lista compacta cuando no haya vistas previas disponibles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面収録のアクセス権が付与されている場合はサムネイルを使用し、プレビューが利用できない場合はコンパクトなリストに切り替えます。"
