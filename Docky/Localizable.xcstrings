    "Sprite mode keeps the leading and trailing thirds of the image pinned and stretches the middle along the dock's axis." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El modo sprite mantiene fijos los tercios inicial y final de la imagen y estira la parte central a lo largo del eje del dock."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スプライトモードは画像の先頭と末尾の3分の1を固定し、中央部分をDockの軸方向に引き伸ばします。"
