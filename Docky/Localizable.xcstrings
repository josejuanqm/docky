            "value" : "再試行"
          }
        }
      }
    },
    "Turn Docky's Cmd-Tab-style switcher on or off without clearing its shortcut or preview preference." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa o desactiva el conmutador estilo Cmd-Tab de Docky sin borrar su atajo ni la preferencia de vista previa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockyのCmd-Tabスタイルスイッチャーのショートカットやプレビュー設定を変更せずに、オン/オフを切り替えます。"
          }
        }
      }
    },
    "Turn Docky's Launchpad overlay on or off without removing its shortcut or layout preferences." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa o desactiva la superposición de Launchpad de Docky sin eliminar su atajo ni las preferencias de diseño."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockyのLaunchpadオーバーレイのショートカットやレイアウト設定を削除せずに、オン/オフを切り替えます。"
          }
        }
      }
    },
    "Turn off to render the chosen image crisp. Default is on to soften the desktop wallpaper into a neutral backdrop." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "オフにすると選択した画像がくっきりと表示されます。デフォルトはオンで、デスクトップの壁紙を柔らかいニュートラルな背景に変換します。"
          }
