            "value" : "トリガーを追加…"
          }
        }
      }
    },
    "Adds a drop shadow behind every icon-bearing tile. Has no visible effect on spacers and dividers." : {
      "comment" : "A description of the shadow feature in the appearance settings.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイコンのあるすべてのタイルの後ろにドロップシャドウを追加します。スペーサや区切り線には視覚的な効果はありません。"
          }
        }
      }
    },
    "Adds a visual separator to break up sections in the dock." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un separador visual para dividir secciones del dock."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dockのセクションを区切る視覚的な区切り線を追加します。"
          }
        }
      }
    },
    "Adds breathing room between pinned tiles or folders." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade espacio entre íconos fijados o carpetas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ピンされたタイルやフォルダ間にスペースを追加します。"
          }
        }
      }
    },
    "Adjusts how transparent the Launchpad backdrop is. Lower values darken the screen behind the grid; higher values let more of your desktop show through." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta la transparencia del fondo del Launchpad. Valores más bajos oscurecen la pantalla detrás de la cuadrícula; los más altos dejan ver más del escritorio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Launchpadの背景の透明度を調整します。値を小さくするとグリッドの後ろの画面が暗くなり、値を大きくするとデスクトップがより透けて見えます。"
          }
        }
      }
    },
