    "Pick a custom image for the Launchpad tile. Defaults to the system Launchpad icon." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige una imagen personalizada para el ícono de Launchpad. Por defecto utiliza el ícono de Launchpad del sistema."
          }
        },
        "ja" : {
          "stringUnit" : {
