        }
      }
    },
    "Optional, a screen recording or screenshot helps explain UI issues. Images and videos are supported." : {
      "comment" : "A description of an optional feedback attachment.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任意で、画面収録またはスクリーンショットを添付するとUIの問題を説明しやすくなります。画像と動画がサポートされています。"
