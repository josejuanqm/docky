    "Stop rearranging icons" : {
      "comment" : "A help text for the \"Reorder\" button when reordering mode is active.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイコンの並べ替えを終了"
          }
        }
      }
    },
    "Stretches to absorb leftover space when the dock spans the full screen axis." : {
      "comment" : "Subtitle for a flexible spacer widget.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dockが画面全体にわたる場合、余白を埋めるように伸縮します。"
          }
        }
      }
    },
    "Support" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サポート"
          }
        }
      }
    },
    "Suppress the hover strip entirely. With multiple profiles you can still switch from Settings or via triggers. With only one profile the strip is always hidden." : {
      "comment" : "A description of the \"Hide profile switcher\" toggle.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホバーストリップを完全に非表示にします。複数のプロファイルがある場合は、設定またはトリガー経由で切り替えられます。プロファイルが1つの場合、ストリップは常に非表示です。"
