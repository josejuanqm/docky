      }
    },
    "Choose Screenshot / Video…" : {
      "comment" : "A button that allows a user to choose a screenshot or video file to attach to their feedback.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スクリーンショット / ビデオを選択…"
          }
        }
      }
    },
    "Choose the global shortcut that opens Docky's Cmd-Tab-style window switcher." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige el atajo global que abre el conmutador de ventanas estilo Cmd-Tab de Docky."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky の Cmd-Tab スタイルの Window Switcher を開くグローバルショートカットを選択してください。"
          }
        }
      }
    },
    "Choose what happens when you click the tile of an app that already has the focus. Clicking idle apps always launches, focuses, or restores their last minimized window." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige qué sucede al hacer clic en el ícono de una app que ya tiene el foco. Al hacer clic en apps inactivas siempre se lanzan, enfocan o restauran su última ventana minimizada."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すでにフォーカスがある App のタイルをクリックしたときの動作を選択してください。アイドル状態の App をクリックすると、常に起動・フォーカス・または最後にしまったウインドウが復元されます。"
          }
        }
      }
    },
    "Choose where Docky sits on screen, or mirror the macOS Dock position." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige dónde se ubica Docky en la pantalla o refleja la posición del Dock de macOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky を画面上のどこに表示するかを選択するか、macOS の Dock の位置に合わせます。"
          }
        }
      }
    },
    "Choose whether Docky appears only in the active Space or joins every Space, including fullscreen auxiliary presentation." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si Docky aparece solo en el Space activo o si se une a todos los Spaces, incluida la presentación auxiliar en pantalla completa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky をアクティブなスペースのみに表示するか、フルスクリーン補助プレゼンテーションを含むすべてのスペースに表示するかを選択してください。"
          }
        }
      }
    },
    "Choose whether Docky hugs its tiles or stretches across the full screen width or height of the current dock axis." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si Docky se ajusta al tamaño de sus íconos o si se extiende por todo el ancho o alto de la pantalla en el eje actual del dock."
          }
        },
        "ja" : {
