        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dock に現在表示されているフォルダタイルにカスタム画像を設定します。各フォルダはデフォルトでシステムアイコンを使用します。"
          }
        }
      }
    },
    "Pick custom images for the Trash tile's empty and full states. Both default to the system Trash icons." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
