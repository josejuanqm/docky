    "Override the chrome outline with a solid color. When off, Docky uses its default glass stroke (or no stroke when Glass is disabled)." : {
      "comment" : "A description of the \"Use Custom Border\" toggle.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クロームのアウトラインを単色でオーバーライドします。オフの場合、Dockyはデフォルトのガラスストロークを使用します（Glassが無効の場合はストロークなし）。"
          }
        }
      }
    },
    "Override the translucent tint behind the main dock window. Leave this off to keep following the system material color." : {
      "localizations" : {
