    "Choose a custom image for any app Docky currently knows about. Custom app icons follow Docky's circle tile clipping when circle tiles are enabled." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige una imagen personalizada para cualquier app que Docky conozca actualmente. Los íconos personalizados siguen el recorte circular de Docky cuando se activan los íconos circulares."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky が認識している任意の App にカスタム画像を選択できます。カスタム App アイコンは、円形タイルが有効なとき Docky の円形タイルクリッピングに従います。"
          }
        }
      }
    },
    "Choose a name for this app folder." : {
