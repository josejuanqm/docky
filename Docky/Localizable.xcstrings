    "Shows Grouping Backdrop" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostrar fondo de agrupación"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "グループ背景を表示"
          }
        }
      }
    },
    "Shows Mac and accessory battery levels at a glance." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra los niveles de batería del Mac y los accesorios de un vistazo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Macとアクセサリのバッテリーレベルを一目で確認できます。"
          }
        }
      }
    },
    "Shows running apps from an app folder immediately to the right of that folder, and lets the folder reflect how many grouped apps are open." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra las apps en ejecución de una carpeta de apps justo a la derecha de esa carpeta y permite que la carpeta refleje cuántas apps agrupadas están abiertas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appフォルダの起動中のAppをそのフォルダのすぐ右に表示し、グループ化された起動中Appの数をフォルダに反映させます。"
          }
        }
      }
    },
    "Shows the current date and month at a glance." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra la fecha y el mes actuales de un vistazo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在の日付と月を一目で確認できます。"
          }
        }
      }
    },
    "Shows the currently playing media with quick playback control." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra el contenido que se está reproduciendo con controles rápidos de reproducción."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在再生中のメディアとクイック再生コントロールを表示します。"
          }
        }
      }
    },
    "Shows the weekday and date number at a glance." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra el día de la semana y el número del día de un vistazo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "曜日と日付を一目で確認できます。"
          }
        }
      }
    },
    "Shows your open tasks and what needs attention next." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra tus tareas abiertas y lo que necesita atención a continuación."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未完了のタスクと次に対応が必要な項目を表示します。"
          }
        }
      }
    },
    "Shrinks the rendered icon inside each tile without changing the tile's layout box. Useful for Windows-style chunky tile slots." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイルのレイアウトを変えずに、各タイル内のアイコン描画サイズを縮小します。Windowsスタイルの大きなタイルスロットに便利です。"
          }
        }
      }
    },
    "Single-key shortcuts that fire while the switcher is open and you're still holding its modifier. Re-bind to any key; navigation keys (Tab, arrows, Escape, Return) always win over a conflicting binding." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スイッチャーが開いており、モディファイアキーを押し続けている間に発動する1キーショートカットです。任意のキーに再割り当て可能です。ただし、ナビゲーションキー（Tab、矢印、Escape、Return）は競合するバインディングより常に優先されます。"
          }
        }
      }
    },
    "Size" : {
      "comment" : "Title of the sorting option for files based on size.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
