            "value" : "ぼかした背景に、インストール済みのすべてのAppを全画面で表示するランチャーです。"
          }
        }
      }
    },
    "Shows CPU, memory, and network activity at a glance." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra la actividad de CPU, memoria y red de un vistazo."
