    "Skip" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omitir"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スキップ"
          }
        }
      }
    },
    "Slide Docky off-screen while a maximized window is on its display, with edge-dwell to reveal." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza Docky fuera de la pantalla mientras hay una ventana maximizada en su pantalla, con espera en el borde para mostrarlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最大化したウインドウが表示されている間、Dockyを画面外にスライドさせます。端にポインタを近づけると再表示されます。"
          }
        }
      }
    },
    "Slides Docky's window off-screen until the pointer reaches its edge. Hide timing is controlled by Docky's own delay below, so hiding the system Dock does not stretch it." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza la ventana de Docky fuera de la pantalla hasta que el puntero llegue a su borde. El tiempo de ocultación se controla con el retraso propio de Docky abajo, por lo que ocultar el Dock del sistema no lo amplía."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポインタが端に届くまでDockyのウインドウを画面外にスライドさせます。非表示のタイミングは下のDocky独自の遅延で制御されるため、システムDockを非表示にしても影響しません。"
          }
        }
      }
    },
