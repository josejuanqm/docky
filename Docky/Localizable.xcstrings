          }
        }
      }
    },
    "Pick a custom image for the Start Menu tile. Defaults to Docky's own app icon." : {
      "comment" : "A label describing the option to set a custom image for the Start Menu tile.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
