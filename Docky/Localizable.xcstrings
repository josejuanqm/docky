        }
      }
    },
    "Shows a fullscreen launcher with all installed apps on a blurred backdrop." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra un lanzador a pantalla completa con todas las apps instaladas sobre un fondo desenfocado."
