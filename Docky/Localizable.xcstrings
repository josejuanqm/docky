      }
    },
    "Drag icons to rearrange them" : {
      "comment" : "A help text describing how to reorder items in a list.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイコンをドラッグして並べ替え"
          }
        }
      }
    },
    "Drag this into the macOS privacy list" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastra esto a la lista de privacidad de macOS"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "macOSのプライバシーリストにドラッグ"
          }
        }
      }
    },
    "Draws a rounded backdrop around the folder tile and its grouped opened apps. Turn off to keep the grouping without the visual halo." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dibuja un fondo redondeado alrededor del ícono de carpeta y las apps abiertas agrupadas. Desactívalo para mantener la agrupación sin el halo visual."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フォルダタイルとグループ化された起動中のAppの周囲に丸みのある背景を描きます。グループ化を維持しながら視覚的なハローを非表示にするには、オフにしてください。"
          }
        }
      }
    },
    "Drop an unzipped `.dockytheme` folder into the Themes directory, then refresh." : {
      "comment" : "A message displayed in the \"Import Theme…\" section of the themes settings view, explaining how to import a theme.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解凍した `.dockytheme` フォルダをテーマディレクトリにドロップして、更新してください。"
          }
        }
      }
    },
    "Duplicate" : {
      "comment" : "A button label that says \"Duplicate\".",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "複製"
          }
        }
      }
    },
    "Each corner that's set overrides only itself; unset corners inherit the uniform radius above. Use this to flatten only the screen-facing edge (taskbar look)." : {
      "comment" : "A description of how to set and unset corner radii for a window.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定された各コーナーはその角のみを上書きします。未設定のコーナーは上記の統一した角の丸みを継承します。スクリーン側のエッジのみをフラットにする場合（タスクバー外観）に使用してください。"
          }
        }
      }
    },
    "Each rendering size can opt into its own content padding and corner radius. Unset values inherit the tile-chrome defaults, useful for letting wide widgets bleed edge-to-edge while keeping the 1x form rounded." : {
      "comment" : "A footer explaining the functionality of the content padding and corner radius settings for each widget size.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レンダリングサイズごとに独自のコンテンツパディングと角の丸みを設定できます。未設定の値はタイルのデフォルトを継承します。1xのフォームを丸みがある状態に保ちながら、幅広のウィジェットをエッジツーエッジで表示するのに便利です。"
          }
        }
      }
    },
